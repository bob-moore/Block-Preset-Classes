{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"landingPage": "/wp-admin/post.php?post=10&action=edit",
	"login": true,
	"features": {
		"networking": true
	},
	"constants": {
		"IS_PLAYGROUND": true
	},
	"steps": [
		{
			"step": "updateUserMeta",
			"meta": {
				"admin_color": "modern",
				"show_welcome_panel": 0
			},
			"userId": 1
		},
		{
			"step": "setSiteOptions",
			"options": {
				"blogname": "Block Preset Classes",
				"permalink_structure": "/%postname%/"
			}
		},
		{
			"step": "installPlugin",
			"pluginData": {
				"resource": "url",
				"url": "https://github.com/bob-moore/Block-Preset-Classes/releases/latest/download/block-preset-classes.zip"
			},
			"options": {
				"activate": true,
				"targetFolderName": "block-preset-classes"
			}
		},
		{
			"step": "importWxr",
			"file": {
				"resource": "url",
				"url": "https://raw.githubusercontent.com/bob-moore/Block-Preset-Classes/main/_playground/demo-content.xml"
			}
		}
	]
}
