		<content:encoded><![CDATA[<!-- wp:group {"className":"has-preset-feature-card has-preset-soft-shadow","layout":{"type":"constrained"}} -->
<div class="wp-block-group has-preset-feature-card has-preset-soft-shadow"><!-- wp:heading {"className":"has-preset-accent-heading"} -->
<h2 class="wp-block-heading has-preset-accent-heading">Block Preset Classes</h2>
<!-- /wp:heading -->

<!-- wp:paragraph {"className":"has-preset-lead-text"} -->
<p class="has-preset-lead-text">This demo registers sample preset options through the <code>block_preset_classes</code> filter, then applies the saved classes to ordinary core blocks.</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"className":"has-preset-accent-note"} -->
<p class="has-preset-accent-note">Open this page in the editor and select the heading, paragraph, or group blocks to see the Block Presets panel.</p>
<!-- /wp:paragraph --></div>
<!-- /wp:group -->

<!-- wp:group {"className":"has-preset-callout-panel has-preset-ribbon-edge","layout":{"type":"constrained"}} -->
<div class="wp-block-group has-preset-callout-panel has-preset-ribbon-edge"><!-- wp:paragraph -->
<p>The plugin does not force a design system. It gives teams a clean way to expose approved CSS classes in the block editor.</p>
<!-- /wp:paragraph --></div>
<!-- /wp:group -->

