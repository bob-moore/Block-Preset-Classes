{
	"name": "block-preset-classes",
	"version": "0.3.4",
	"description": "Adds configurable preset classes to Gutenberg blocks.",
	"author": "Bob Moore",
	"license": "GPL-2.0-or-later",
	"keywords": [
		"wordpress",
		"gutenberg",
		"blocks",
		"css",
		"presets"
	],
	"homepage": "https://github.com/bob-moore/Block-Preset-Classes",
	"repository": {
		"type": "git",
		"url": "git://github.com/bob-moore/Block-Preset-Classes.git"
	},
	"bugs": {
		"url": "https://github.com/bob-moore/Block-Preset-Classes/issues"
	},
	"private": true,
	"engines": {
		"node": ">=18.12.0",
		"npm": ">=8.19.2"
	},
	"files": [
		"block-preset-classes.php",
		"build",
		"assets",
		"!build/*.map",
		"vendor/autoload.php",
		"vendor/composer",
		"vendor/scoped",
		"readme.txt",
		"inc"
	],
	"dependencies": {
		"react-select": "^5.10.2"
	},
	"devDependencies": {
		"@wordpress/api-fetch": "^7.37.0",
		"@wordpress/block-editor": "^15.10.0",
		"@wordpress/components": "^31.0.0",
		"@wordpress/compose": "^7.37.0",
		"@wordpress/data": "^10.37.0",
		"@wordpress/element": "^6.37.0",
		"@wordpress/hooks": "^4.37.0",
		"@wordpress/icons": "^11.4.0",
		"@wordpress/scripts": "^32.1.0",
		"@wordpress/stylelint-config": "^23.29.0",
		"mini-css-extract-plugin": "^2.9.4",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"stylelint": "^16.26.1",
		"stylelint-scss": "^6.14.0",
		"typescript": "^5.9.3",
		"webpack-remove-empty-scripts": "^1.1.1"
	},
	"scripts": {
		"build": "wp-scripts build --experimental-modules",
		"format": "wp-scripts format",
		"lint:css": "wp-scripts lint-style './src/**/*.scss'",
		"lint:js": "wp-scripts lint-js './src/**/*.ts' './src/**/*.tsx'",
		"lint:md:docs": "wp-scripts lint-md-docs",
		"lint:pkg-json": "wp-scripts lint-pkg-json",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "wp-scripts plugin-zip --root-folder=block-preset-classes",
		"start": "wp-scripts start --experimental-modules"
	}
}
